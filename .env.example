# OpenAI API key for Whisper transcription and GPT-4o idea refinement
OPENAI_API_KEY=sk-your-key-here

# Session signing secret (min 32 chars, generate with: openssl rand -hex 32)
SESSION_SECRET=generate-a-64-char-hex-string

# Password used when seeding initial user accounts (required for first run)
SEED_PASSWORD=change-me-to-a-strong-password
